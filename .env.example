# Local Postgres:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ccd_exit_clearance

# Supabase direct connection or pooler connection:
# Use the connection string from Supabase Dashboard > Project Settings > Database.
# Keep sslmode=require for Supabase. URL-encode password symbols, for example @ becomes %40.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?sslmode=require

SUPABASE_STORAGE_URL=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
SUPABASE_ANON_URL=YOUR_SUPABASE_ANON_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
JWT_SECRET=your_super_secret_key_at_least_32_characters_long_change_in_production
CLIENT_URL=http://localhost:5173/
PORT=8080
